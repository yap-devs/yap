{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "./.opencode/plugin/laravel-boost.js"
    ],
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": false,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        },
        "sentry": {
            "type": "remote",
            "url": "https://mcp.sentry.dev/mcp",
            "enabled": true
        }
    }
}
